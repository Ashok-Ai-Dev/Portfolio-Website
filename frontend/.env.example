## Frontend environment variables (Vite)

# GitHub API (optional token helps avoid rate limits)
VITE_GITHUB_USERNAME=Ashok-Ai-Dev
VITE_GITHUB_TOKEN=

# EmailJS
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional: if you later route GitHub through backend (Render)
VITE_API_BASE_URL=https://github.com/Ashok-Ai-Dev

